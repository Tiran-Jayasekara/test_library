{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",      // This handles modern resolution
    "moduleResolution": "NodeNext",
    "declaration": true,       // Generates .d.ts files for your users
    "outDir": "./dist",
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}